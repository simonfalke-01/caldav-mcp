# Required: generate a long random value, for example: openssl rand -hex 32
MCP_API_KEY=replace-with-a-long-random-secret

# Required for iCloud. Use an app-specific password, never your Apple ID password.
ICLOUD_USERNAME=you@example.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional settings
PORT=8000
CALDAV_URL=https://caldav.icloud.com
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC

